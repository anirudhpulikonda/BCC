# Exclude static files and special pages from the trailing slash redirect
/sitemap.xml  /sitemap.xml  200
/sitemap-*.xml  /sitemap-:splat.xml  200
/favicon.svg  /favicon.svg  200
/robots.txt  /robots.txt  200
/404  /404  200

# Legacy WordPress category URLs
/category/sports/football/  /sports/football/  301
/category/sports/football  /sports/football/  301

# Redirect all other URLs without trailing slash to trailing slash
/:splat  /:splat/  301
