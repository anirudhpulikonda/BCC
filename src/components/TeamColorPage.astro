---
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import '../styles/global.css';

interface Color {
  name: string;
  hex: string;
  rgb: { r: number; g: number; b: number };
  cmyk: { c: number; m: number; y: number; k: number };
  pantone: string;
}

interface RelatedTeam {
  teamName: string;
  slug: string;
  colors: Color[];
}

interface Props {
  teamName: string;
  league: string;
  slug: string;
  colors: Color[];
  logoPath: string;
  sourcingNote: string;
  relatedTeams?: RelatedTeam[];
}

const { teamName, league, colors, logoPath, sourcingNote, relatedTeams = [] } = Astro.props;

const colorNames = colors.map(c => c.name);
const colorList = colorNames.length <= 2
  ? colorNames.join(' and ')
  : colorNames.slice(0, -1).join(', ') + ', and ' + colorNames.at(-1);
const intro = `The ${teamName} colors are ${colorList}. The official ${teamName} color codes for all ${colors.length} team color${colors.length !== 1 ? 's' : ''} are listed below in hex, RGB, CMYK, and Pantone so designers and fans can use them in any project.`;

const title = `${teamName} Colors – Hex, RGB, CMYK & Pantone Codes | BCC`;
const description = `Explore the official ${teamName} color codes including hex, RGB, CMYK, and Pantone values. The complete ${teamName} brand color palette for designers and fans.`;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <Nav />

  <section class="hero">
    <div class="hero-inner">
      <img
        class="hero-logo"
        src={logoPath}
        alt={`${teamName} logo`}
        width="110"
        height="110"
      />
      <div class="hero-text">
        <h1>{teamName} colors</h1>
        <p class="hero-sub">Official brand color codes — hex, RGB, CMYK, and Pantone</p>
        <div class="hero-meta">
          <span class="badge">{league}</span>
          <span class="hero-count">{colors.length} colors</span>
        </div>
        <div class="swatch-strip">
          {colors.map(c => (
            <div class="swatch-dot" style={`background:${c.hex}`} title={c.name}></div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <main class="main">
    <p class="intro">{intro}</p>
    <p class="section-label">Color codes</p>
    <div class="colors-grid">
      {colors.map(c => (
        <div class="color-card">
          <div class="color-swatch" style={`background:${c.hex}`}></div>
          <div class="color-card-body">
            <p class="color-name">{c.name}</p>
            <div class="color-values">
              {[
                ['HEX',     c.hex],
                ['RGB',     `${c.rgb.r}, ${c.rgb.g}, ${c.rgb.b}`],
                ['CMYK',    `${c.cmyk.c}, ${c.cmyk.m}, ${c.cmyk.y}, ${c.cmyk.k}`],
                ['Pantone', c.pantone],
              ].map(([label, val]) => (
                <div class="color-row">
                  <span class="color-label">{label}</span>
                  <span class="color-val" title={val}>{val}</span>
                  <button class="copy-btn" data-copy={val} aria-label={`Copy ${label} value`}>Copy</button>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <p class="sourcing">{sourcingNote}</p>

    {relatedTeams.length > 0 && (
      <>
        <div class="divider"></div>
        <a class="section-label section-label-link" href={`/${league.toLowerCase()}/`}>Other {league} teams →</a>
        <div class="related-grid">
          {relatedTeams.map(t => (
            <a class="related-card" href={`/${t.slug}/`}>
              <div class="rel-dots">
                {t.colors.slice(0, 2).map(c => (
                  <div class="rel-dot" style={`background:${c.hex}`}></div>
                ))}
              </div>
              <div class="related-card-text">
                <p class="rel-name">{t.teamName}</p>
                <p class="rel-league">{league}</p>
              </div>
              <span class="rel-arrow" aria-hidden="true">›</span>
            </a>
          ))}
        </div>
      </>
    )}
  </main>

  <Footer />
</body>
</html>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const value = btn.dataset.copy ?? '';
      navigator.clipboard.writeText(value).then(() => {
        btn.classList.add('copied');
        btn.textContent = 'Copied';
        setTimeout(() => {
          btn.classList.remove('copied');
          btn.textContent = 'Copy';
        }, 1500);
      });
    });
  });
</script>

<style>
  .hero {
    padding: 3rem 2rem 2.5rem;
    border-bottom: 0.5px solid var(--border);
    background: var(--surface-1);
  }

  .hero-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .hero-logo {
    width: 110px;
    height: 110px;
    object-fit: contain;
    flex-shrink: 0;
    border-radius: 12px;
    background: var(--surface-2);
    padding: 14px;
    border: 0.5px solid var(--border);
  }

  .hero-text h1 {
    font-size: 28px;
    font-weight: 500;
    line-height: 1.2;
    margin-bottom: 6px;
  }

  .hero-sub {
    font-size: 14px;
    color: var(--text-secondary);
    margin-top: 4px;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 10px;
  }

  .badge {
    font-size: 12px;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 20px;
    background: var(--bg-accent);
    color: var(--text-accent);
    border: 0.5px solid var(--border-accent);
  }

  .hero-count {
    font-size: 12px;
    color: var(--text-muted);
  }

  .swatch-strip {
    display: flex;
    gap: 6px;
    margin-top: 16px;
  }

  .swatch-dot {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 0.5px solid var(--border-strong);
  }

  .main {
    max-width: 900px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
  }

  .intro {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 680px;
  }

  .section-label-link {
    text-decoration: none;
    color: var(--text-accent);
  }

  .section-label-link:hover {
    text-decoration: underline;
  }

  .section-label {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .colors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 12px;
    margin-bottom: 3rem;
  }

  .color-card {
    background: var(--surface-2);
    border: 0.5px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .color-swatch {
    height: 100px;
    width: 100%;
    display: block;
  }

  .color-card-body {
    padding: 14px;
  }

  .color-name {
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 12px;
    color: var(--text-primary);
  }

  .color-values {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .color-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .color-label {
    font-size: 11px;
    color: var(--text-muted);
    font-weight: 500;
    min-width: 46px;
  }

  .color-val {
    font-size: 11px;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .copy-btn {
    background: none;
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    padding: 2px 7px;
    font-size: 11px;
    font-family: var(--font-sans);
    color: var(--text-muted);
    cursor: pointer;
    white-space: nowrap;
    transition: background .12s, color .12s;
  }

  .copy-btn:hover {
    background: var(--surface-1);
    color: var(--text-primary);
    border-color: var(--border-strong);
  }

  .copy-btn.copied {
    color: var(--text-success);
    border-color: var(--border-success);
  }

  .sourcing {
    font-size: 12px;
    color: var(--text-muted);
    padding: 10px 14px;
    background: var(--surface-1);
    border-radius: var(--radius);
    border: 0.5px solid var(--border);
    margin-bottom: 3rem;
    line-height: 1.6;
  }

  .divider {
    height: 0.5px;
    background: var(--border);
    margin: 2rem 0;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 10px;
    margin-bottom: 3rem;
  }

  .related-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    background: var(--surface-2);
    border: 0.5px solid var(--border);
    border-radius: 12px;
    transition: background .12s, border-color .12s;
  }

  .related-card:hover {
    background: var(--surface-1);
    border-color: var(--border-strong);
  }

  .rel-dots {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
  }

  .rel-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 0.5px solid var(--border);
  }

  .related-card-text { flex: 1; min-width: 0; }

  .rel-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .rel-league {
    font-size: 11px;
    color: var(--text-muted);
  }

  .rel-arrow {
    font-size: 16px;
    color: var(--text-muted);
  }
</style>
