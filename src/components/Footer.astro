---
import { getCollection } from 'astro:content';

const all = await getCollection('teams');

const leagues = [
  { name: 'NFL', label: 'NFL Team Colors', slug: 'nfl-team-color-codes' },
  { name: 'NBA', label: 'NBA Team Colors', slug: 'nba-team-color-codes' },
  { name: 'NHL', label: 'NHL Team Colors', slug: 'nhl-team-color-codes' },
  { name: 'MLB', label: 'MLB Team Colors', slug: 'mlb-team-color-codes' },
];

const leagueTeams = Object.fromEntries(
  leagues.map(l => [
    l.name,
    all
      .filter(t => t.data.league === l.name)
      .sort((a, b) => a.data.teamName.localeCompare(b.data.teamName))
      .slice(0, 4),
  ])
);
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-cols">
      {leagues.map(l => (
        <div class="footer-col">
          <a class="col-heading" href={`/${l.slug}/`}>{l.label}</a>
          <ul>
            {leagueTeams[l.name].map(t => (
              <li><a href={`/${t.data.slug}/`}>{t.data.teamName}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="footer-bottom">
      <div class="footer-legal-links">
        <a href="/disclaimer/">Disclaimer</a>
        <span>·</span>
        <a href="/privacy-policy/">Privacy Policy</a>
      </div>
      <p class="footer-copy">Brand color data sourced from official team guidelines. Not affiliated with any league or team.</p>
      <p class="footer-copy footer-copyright">© {new Date().getFullYear()} Best Color Codes. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 0.5px solid var(--border);
    background: var(--surface-1);
    padding: 3rem 2rem 2rem;
  }

  .footer-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .footer-col ul {
    list-style: none;
    margin-top: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .col-heading {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: 0.01em;
  }

  .col-heading:hover { color: var(--text-accent); }

  .footer-col ul a {
    font-size: 13px;
    color: var(--text-secondary);
    transition: color .1s;
  }

  .footer-col ul a:hover { color: var(--text-primary); }

  .footer-bottom {
    border-top: 0.5px solid var(--border);
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-align: center;
  }

  .footer-legal-links {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
  }

  .footer-legal-links a {
    font-size: 12px;
    color: var(--text-secondary);
    transition: color .1s;
  }

  .footer-legal-links a:hover { color: var(--text-primary); }

  .footer-legal-links span {
    font-size: 12px;
    color: var(--text-muted);
  }

  .footer-copy {
    font-size: 12px;
    color: var(--text-muted);
  }

  @media (max-width: 600px) {
    .footer-cols {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
