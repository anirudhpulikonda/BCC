---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import JsonLd from '../components/JsonLd.astro';
import { site } from '../config/site';

const all = await getCollection('teams');
const teams = all
  .filter(t => t.data.league === 'NHL')
  .sort((a, b) => a.data.teamName.localeCompare(b.data.teamName));

const leagueUrl = `${site.url}/nhl-team-color-codes/`;

const colorTeams: Record<string, Set<string>> = {};
for (const t of teams) {
  for (const c of t.data.colors) {
    const name = c.name.toLowerCase();
    let bucket: string;
    if (name.includes('gold') || name.includes('yellow')) bucket = 'Gold / Yellow';
    else if (name.includes('red') || name.includes('scarlet')) bucket = 'Red';
    else if (name.includes('black')) bucket = 'Black';
    else if (name.includes('blue') || name.includes('navy')) bucket = 'Blue';
    else if (name.includes('green')) bucket = 'Green';
    else if (name.includes('silver') || name.includes('white')) bucket = 'Silver / White';
    else if (name.includes('orange')) bucket = 'Orange';
    else bucket = 'Other';
    if (!colorTeams[bucket]) colorTeams[bucket] = new Set();
    colorTeams[bucket].add(t.data.teamName);
  }
}
const colorRanking = Object.entries(colorTeams)
  .map(([color, teamSet]) => ({ color, teams: [...teamSet] }))
  .sort((a, b) => b.teams.length - a.teams.length);

const breadcrumbs = [
  { name: 'Best Color Codes', url: `${site.url}/` },
  { name: 'Sports', url: `${site.url}/sports/` },
  { name: 'Hockey', url: `${site.url}/sports/hockey/` },
  { name: 'NHL', url: leagueUrl },
];

const sportsOrgSchema = {
  '@context': 'https://schema.org',
  '@type': 'SportsOrganization',
  name: 'National Hockey League',
  alternateName: 'NHL',
  sport: 'Ice Hockey',
  url: leagueUrl,
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'NHL Team Colors',
  description: `Official color codes for all ${teams.length} NHL teams on Best Color Codes.`,
  url: leagueUrl,
  numberOfItems: teams.length,
  itemListElement: teams.map((t, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: `${t.data.teamName} Colors`,
    url: `${site.url}/${t.data.slug}/`,
  })),
};

const colorMeanings = [
  { team: 'Boston Bruins', meaning: 'Black and gold were chosen in 1924 to stand out from other teams. The colors have become iconic - representing the working-class grit of Boston and making the Bruins one of the most visually recognizable franchises in hockey.' },
  { team: 'Dallas Stars', meaning: 'Victory green, black, and gold reflect Texas pride and the lone star identity of the state. The green was a bold choice when introduced in 1993 - making Dallas one of the few major sports teams to use green as a primary color.' },
  { team: 'Edmonton Oilers', meaning: 'Royal blue and burnt orange reflect the oil industry that defines Edmonton\'s economy. The colors were chosen to be bold and distinctive when the franchise entered the NHL from the WHA in 1979.' },
  { team: 'Nashville Predators', meaning: 'Navy blue, gold, and white were chosen in 1997 to evoke power and prestige. The gold references Nashville\'s music industry and connection to country music gold records.' },
  { team: 'Toronto Maple Leafs', meaning: 'Blue and white honor the Canadian national colors and the maple leaf - Canada\'s most recognizable symbol. The franchise has used some form of blue and white since 1917, making it one of the most consistent color identities in all of sports.' },
];

const logoMeanings = [
  { team: 'Boston Bruins', symbol: 'A spoked "B" in a wheel design - introduced in 1948 and refined over decades. The wheel spoke pattern references the team\'s original connection to the Boston Athletic Association and conveys speed and motion.' },
  { team: 'Dallas Stars', symbol: 'A star with a skate blade cutting through it - tying the Texas lone star identity directly to the sport of hockey. The logo\'s green and gold color scheme made it instantly distinctive when the franchise moved from Minnesota in 1993.' },
  { team: 'Edmonton Oilers', symbol: 'An oil drop shape containing a skater - directly referencing the oil industry that powers Edmonton. Simple, bold, and immediately tied to the city\'s economic identity.' },
  { team: 'Nashville Predators', symbol: 'A saber-toothed tiger - referencing the prehistoric Smilodon fossils discovered during the construction of the arena. The predator theme was chosen to give Nashville a fierce, aggressive identity.' },
  { team: 'Toronto Maple Leafs', symbol: 'A stylized maple leaf - one of the most iconic logos in hockey. The 13-point leaf has been updated multiple times, with the most significant redesign in 2016 returning to a cleaner, more classic look.' },
];

const crossLeague = [
  { nhl: 'Boston Bruins', similar: 'Pittsburgh Steelers (NFL) - both use black and gold, creating a working-class, industrial aesthetic that resonates with blue-collar fan bases.' },
  { nhl: 'Toronto Maple Leafs', similar: 'Toronto Raptors (NBA) - both Toronto franchises use blue and red respectively, giving the city a consistent sports color identity.' },
  { nhl: 'Nashville Predators', similar: 'Pittsburgh Steelers (NFL) and Golden State Warriors (NBA) - all use blue and gold as core palette colors, though the shade of gold varies significantly.' },
  { nhl: 'Dallas Stars', similar: 'Green Bay Packers (NFL) and Oakland Athletics (MLB) - all use green and gold, a relatively rare combination in major American sports.' },
  { nhl: 'Edmonton Oilers', similar: 'New York Mets (MLB) and New York Knicks (NBA) - all use royal blue and orange, a bold complementary color pairing.' },
];

const historicalTeams = [
  { name: 'Quebec Nordiques', era: '1972-1995', notes: 'Relocated to Colorado and became the Colorado Avalanche. The Nordiques wore blue, red, and white with a distinctive igloo logo - colors that remain beloved by Quebec hockey fans.' },
  { name: 'Hartford Whalers', era: '1979-1997', notes: 'Relocated to Carolina and became the Hurricanes. The Whalers\' teal, green, and white is considered one of the best color schemes in hockey history - their logo a fan favorite to this day.' },
  { name: 'Minnesota North Stars', era: '1967-1993 (Minnesota)', notes: 'Relocated to Dallas in 1993 and became the Stars, dropping the green and gold color scheme. Minnesota later received an expansion team, the Wild, in 2000.' },
  { name: 'Atlanta Thrashers', era: '1999-2011', notes: 'Relocated to Winnipeg in 2011 and became the Jets. The Thrashers wore blue, red, and gold with a thrasher bird logo - colors retired when the franchise moved north.' },
];
---

<Base
  title="NHL Team Colors - Hex, RGB, CMYK & Pantone Codes | Best Color Codes"
  description={`Official NHL team color codes for all ${teams.length} teams. Find the exact HEX, RGB, CMYK, and Pantone values for every National Hockey League team.`}
  breadcrumbs={breadcrumbs}
>
  <Fragment slot="head">
    <JsonLd schema={sportsOrgSchema} />
    <JsonLd schema={itemListSchema} />
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <div class="breadcrumb">
        <a href="/">Best Color Codes</a> <span>›</span>
        <a href="/sports/">Sports</a> <span>›</span>
        <a href="/sports/hockey/">Hockey</a> <span>›</span>
        <span>NHL</span>
      </div>
      <h1>NHL team colors</h1>
      <p class="hero-sub">National Hockey League - official brand color codes for all {teams.length} teams.</p>
    </div>
  </section>

  <main class="main">

    <section class="prose-block">
      <p>The <strong>National Hockey League (NHL)</strong> is divided into two conferences - the Eastern Conference and the Western Conference - each with 16 teams. The reigning Stanley Cup champions are the <strong>Florida Panthers</strong>. Best Color Codes currently covers {teams.length} NHL teams, with new team pages being added regularly. Every entry includes official HEX, RGB, CMYK, and Pantone values sourced from team brand guidelines and verified SVG artwork.</p>
    </section>

    <section class="team-section">
      <p class="section-label">{teams.length} teams</p>
      <div class="team-grid">
        {teams.map(t => (
          <a class="team-card" href={`/${t.data.slug}/`}>
            <div class="color-strip">
              {t.data.colors.map(c => (
                <div class="strip-seg" style={`background:${c.hex}`}></div>
              ))}
            </div>
            <div class="card-body">
              <h2 class="team-name">{t.data.teamName}</h2>
              <p class="team-count">{t.data.colors.length} colors</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <div class="divider"></div>

    <section class="prose-block">
      <h2>Most common NHL team colors</h2>
      <p>Across the {teams.length} NHL teams on Best Color Codes, blue is the dominant color - reflecting hockey's association with ice, cold, and the Canadian winters where the sport was born.</p>
      <div class="color-table-wrap">
        <table class="color-table">
          <thead>
            <tr><th>Color family</th><th>Teams</th></tr>
          </thead>
          <tbody>
            {colorRanking.map(({ color, teams: t }) => (
              <tr>
                <td>{color}</td>
                <td>{t.join(', ')}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="table-note">Note: colors are grouped into families (e.g. "Bruins Gold" and "Predators Gold" both count under Gold / Yellow).</p>
    </section>

    <div class="divider"></div>

    <section class="prose-block">
      <h2>NHL team HEX color codes</h2>
      <p>HEX codes are the standard for web and digital design. Every value below is the official HEX code confirmed from team brand materials.</p>
      <div class="color-table-wrap">
        <table class="color-table">
          <thead>
            <tr><th>Team</th><th>Color</th><th>HEX</th></tr>
          </thead>
          <tbody>
            {teams.map(t => t.data.colors.map((c, i) => (
              <tr>
                {i === 0 && <td rowspan={t.data.colors.length} class="team-cell">{t.data.teamName}</td>}
                <td>{c.name}</td>
                <td><span class="swatch-inline" style={`background:${c.hex}`}></span><code>{c.hex}</code></td>
              </tr>
            )))}
          </tbody>
        </table>
      </div>
    </section>

    <div class="divider"></div>

    <section class="prose-block">
      <h2>NHL team RGB color codes</h2>
      <p>RGB values are used in digital displays, video production, and on-screen design tools. Each value represents Red, Green, and Blue channels on a 0-255 scale.</p>
      <div class="color-table-wrap">
        <table class="color-table">
          <thead>
            <tr><th>Team</th><th>Color</th><th>RGB</th></tr>
          </thead>
          <tbody>
            {teams.map(t => t.data.colors.map((c, i) => (
              <tr>
                {i === 0 && <td rowspan={t.data.colors.length} class="team-cell">{t.data.teamName}</td>}
                <td>{c.name}</td>
                <td><code>{c.rgb.r}, {c.rgb.g}, {c.rgb.b}</code></td>
              </tr>
            )))}
          </tbody>
        </table>
      </div>
    </section>

    <div class="divider"></div>

    <section class="prose-block">
      <h2>NHL team CMYK color codes</h2>
      <p>CMYK values are used in print design and physical merchandise. The four channels - Cyan, Magenta, Yellow, and Key (Black) - represent how ink is mixed for printing.</p>
      <div class="color-table-wrap">
        <table class="color-table">
          <thead>
            <tr><th>Team</th><th>Color</th><th>CMYK</th></tr>
          </thead>
          <tbody>
            {teams.map(t => t.data.colors.map((c, i) => (
              <tr>
                {i === 0 && <td rowspan={t.data.colors.length} class="team-cell">{t.data.teamName}</td>}
                <td>{c.name}</td>
                <td><code>{c.cmyk.c}, {c.cmyk.m}, {c.cmyk.y}, {c.cmyk.k}</code></td>
              </tr>
            )))}
          </tbody>
        </table>
      </div>
    </section>

    <div class="divider"></div>

    <section class="prose-block">
      <h2>NHL team Pantone color codes</h2>
      <p>Pantone (PMS) codes are the industry standard for brand color consistency across physical products - from jerseys to arena signage to merchandise.</p>
      <div class="color-table-wrap">
        <table class="color-table">
          <thead>
            <tr><th>Team</th><th>Color</th><th>Pantone</th></tr>
          </thead>
          <tbody>
            {teams.map(t => t.data.colors.map((c, i) => (
              <tr>
                {i === 0 && <td rowspan={t.data.colors.length} class="team-cell">{t.data.teamName}</td>}
                <td>{c.name}</td>
                <td><code>{c.pantone}</code></td>
              </tr>
            )))}
          </tbody>
        </table>
      </div>
    </section>

    <div class="divider"></div>

    <section class="prose-block">
      <h2>What do NHL team colors mean?</h2>
      <p>NHL team colors often reflect the city's heritage, geography, or the symbolism tied to the team's name.</p>
      <div class="meaning-list">
        {colorMeanings.map(m => (
          <div class="meaning-item">
            <p class="meaning-team">{m.team}</p>
            <p class="meaning-text">{m.meaning}</p>
          </div>
        ))}
      </div>
    </section>

    <div class="divider"></div>

    <section class="prose-block">
      <h2>NHL team logo meanings</h2>
      <p>NHL logos blend sporting identity with city and regional pride, often using imagery tied to history, geography, or local culture.</p>
      <div class="meaning-list">
        {logoMeanings.map(m => (
          <div class="meaning-item">
            <p class="meaning-team">{m.team}</p>
            <p class="meaning-text">{m.symbol}</p>
          </div>
        ))}
      </div>
      <h3>How to recreate an NHL logo</h3>
      <p>If you're designing fan art or a creative project using NHL team colors, here's a general workflow:</p>
      <ol class="steps-list">
        <li><strong>Get the official colors</strong> - use the HEX, RGB, and Pantone values from this page or the team's individual color page.</li>
        <li><strong>Source the logo SVG</strong> - official SVG logos are available through the NHL's press kit or Wikimedia Commons for reference use.</li>
        <li><strong>Open in a vector tool</strong> - Adobe Illustrator, Figma, or Affinity Designer all work well for SVG editing.</li>
        <li><strong>Apply official colors</strong> - replace any approximate colors with the exact values from team brand guidelines.</li>
        <li><strong>Respect usage rights</strong> - NHL team logos are trademarked. Fan art is generally tolerated but commercial use requires licensing.</li>
      </ol>
    </section>

    <div class="divider"></div>

    <section class="prose-block">
      <h2>NHL teams with similar colors to other leagues</h2>
      <p>Several NHL teams share their color palette with franchises across the NFL, NBA, and MLB - creating cross-sport color connections.</p>
      <div class="meaning-list">
        {crossLeague.map(m => (
          <div class="meaning-item">
            <p class="meaning-team">{m.nhl}</p>
            <p class="meaning-text">{m.similar}</p>
          </div>
        ))}
      </div>
    </section>

    <div class="divider"></div>

    <section class="prose-block">
      <h2>Historical NHL teams and their colors</h2>
      <p>Several NHL franchises have relocated or folded over the decades, leaving behind memorable color legacies.</p>
      <div class="color-table-wrap">
        <table class="color-table">
          <thead>
            <tr><th>Team</th><th>Era</th><th>Notes</th></tr>
          </thead>
          <tbody>
            {historicalTeams.map(t => (
              <tr>
                <td class="team-cell">{t.name}</td>
                <td><code>{t.era}</code></td>
                <td>{t.notes}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

  </main>
</Base>

<style>
  .hero {
    padding: 3rem 2rem 2.5rem;
    background: var(--surface-1);
    border-bottom: 0.5px solid var(--border);
  }

  .hero-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .breadcrumb {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 1rem;
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .breadcrumb a { color: var(--text-accent); }
  .breadcrumb a:hover { text-decoration: underline; }

  h1 {
    font-size: 28px;
    font-weight: 500;
    line-height: 1.2;
    margin-bottom: 8px;
  }

  .hero-sub {
    font-size: 14px;
    color: var(--text-secondary);
  }

  .main {
    max-width: 900px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
  }

  .section-label {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .team-section { margin-bottom: 3rem; }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 10px;
  }

  .team-card {
    background: var(--surface-2);
    border: 1px solid var(--border-strong);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color .12s;
    text-decoration: none;
  }

  .team-card:hover { border-color: var(--border-strong); }

  .color-strip { display: flex; height: 6px; }
  .strip-seg { flex: 1; }

  .card-body { padding: 14px 16px; }

  .team-name {
    font-size: 16px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .team-count {
    font-size: 11px;
    color: var(--text-muted);
  }

  .prose-block { margin-bottom: 3rem; }

  .prose-block h2 {
    font-size: 20px;
    font-weight: 500;
    margin-bottom: 12px;
    color: var(--text-primary);
  }

  .prose-block h3 {
    font-size: 15px;
    font-weight: 500;
    margin: 1.5rem 0 10px;
    color: var(--text-primary);
  }

  .prose-block p {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .prose-block strong { color: var(--text-primary); font-weight: 500; }

  .color-table-wrap {
    overflow-x: auto;
    margin-bottom: 1rem;
    border: 1px solid var(--border-strong);
    border-radius: 10px;
  }

  .color-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 16px;
  }

  .color-table th {
    text-align: left;
    padding: 10px 14px;
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--text-muted);
    border-bottom: 0.5px solid var(--border);
    background: var(--surface-1);
  }

  .color-table td {
    padding: 10px 14px;
    border-bottom: 0.5px solid var(--border);
    color: var(--text-primary);
    vertical-align: middle;
  }

  .color-table tr:last-child td { border-bottom: none; }

  .color-table code {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--text-primary);
  }

  .team-cell {
    color: var(--text-primary);
    font-weight: 500;
    white-space: nowrap;
  }

  .swatch-inline {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 3px;
    margin-right: 8px;
    vertical-align: middle;
    border: 1px solid var(--border-strong);
  }

  .table-note {
    font-size: 12px !important;
    color: var(--text-muted) !important;
  }

  .meaning-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .meaning-item {
    padding: 14px 16px;
    border-bottom: 0.5px solid var(--border);
  }

  .meaning-item:last-child { border-bottom: none; }

  .meaning-team {
    font-size: 16px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 4px !important;
  }

  .meaning-text {
    font-size: 16px !important;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 0 !important;
  }

  .steps-list {
    padding-left: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 1rem;
  }

  .steps-list li {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .steps-list strong { color: var(--text-primary); font-weight: 500; }

  .divider {
    height: 0.5px;
    background: var(--border);
    margin-bottom: 3rem;
  }
</style>
