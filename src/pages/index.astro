---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const all = await getCollection('teams');

const leagues = [
  { name: 'NFL', slug: 'nfl-team-color-codes', full: 'National Football League' },
  { name: 'NBA', slug: 'nba-team-color-codes', full: 'National Basketball Association' },
  { name: 'NHL', slug: 'nhl-team-color-codes', full: 'National Hockey League' },
  { name: 'MLB', slug: 'mlb-team-color-codes', full: 'Major League Baseball' },
];

const leagueTeams = Object.fromEntries(
  leagues.map(l => [l.name, all.filter(t => t.data.league === l.name).slice(0, 4)])
);
---

<Base
  title="Best Color Codes - Sports Team HEX, RGB, CMYK & Pantone"
  description="The definitive reference for sports team brand colors. Find official HEX, RGB, CMYK, and Pantone codes for every NFL, NBA, NHL, and MLB team."
>
  <section class="hero">
    <div class="hero-inner">
      <h1>Sports team<br/>color codes</h1>
      <p class="hero-sub">Official HEX, RGB, CMYK, and Pantone values for every team - confirmed from brand guidelines and official assets.</p>
      <div class="hero-actions">
        <a class="hero-btn primary" href="/sports/">Browse all sports</a>
        <a class="hero-btn secondary" href="/sports/football/">Football leagues</a>
      </div>
    </div>
  </section>

  <main class="main">
    <div class="categories">
      <a class="category-pill" href="/sports/football/">🏈 Football</a>
      <a class="category-pill" href="/sports/basketball/">🏀 Basketball</a>
      <a class="category-pill" href="/sports/hockey/">🏒 Hockey</a>
      <a class="category-pill" href="/sports/baseball/">⚾ Baseball</a>
      <a class="category-pill" href="/sports/footwear/">👟 Footwear</a>
    </div>

    {leagues.map(league => (
      <div class="league-section">
        <div class="league-header">
          <div class="league-title-wrap">
            <span class="league-badge">{league.name}</span>
            <p class="league-full">{league.full}</p>
          </div>
          <a class="see-all" href={`/${league.slug}/`}>See all {league.name} teams →</a>
        </div>
        <div class="team-grid">
          {leagueTeams[league.name].map(t => (
            <a class="team-card" href={`/${t.data.slug}/`}>
              <div class="color-strip">
                {t.data.colors.map(c => (
                  <div class="strip-seg" style={`background:${c.hex}`}></div>
                ))}
              </div>
              <div class="card-body">
                <h2 class="team-name">{t.data.teamName}</h2>
                <p class="team-count">{t.data.colors.length} colors</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </main>
</Base>

<style>
  .hero {
    padding: 4rem 2rem 3rem;
    background: var(--surface-1);
    border-bottom: 0.5px solid var(--border);
  }

  .hero-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .hero-inner h1 {
    font-size: 48px;
    font-weight: 500;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .hero-sub {
    font-size: 16px;
    color: var(--text-secondary);
    max-width: 520px;
    margin-bottom: 1.75rem;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .hero-btn {
    padding: 10px 20px;
    border-radius: var(--radius);
    font-size: 14px;
    font-weight: 500;
    transition: opacity .12s;
  }

  .hero-btn.primary {
    background: var(--text-primary);
    color: var(--surface-2);
  }

  .hero-btn.secondary {
    background: var(--surface-2);
    border: 0.5px solid var(--border-strong);
    color: var(--text-primary);
  }

  .hero-btn:hover { opacity: .85; }

  .main {
    max-width: 900px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
  }

  .categories {
    display: flex;
    gap: 8px;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .category-pill {
    padding: 8px 18px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 500;
    background: var(--surface-2);
    border: 0.5px solid var(--border-strong);
    color: var(--text-primary);
    transition: background .12s, border-color .12s;
  }

  .category-pill:hover {
    background: var(--bg-accent);
    border-color: var(--border-accent);
    color: var(--text-accent);
  }

  .league-section { margin-bottom: 3rem; }

  .league-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    gap: 8px;
  }

  .league-title-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .league-badge {
    font-size: 12px;
    font-weight: 600;
    padding: 3px 10px;
    background: var(--bg-accent);
    color: var(--text-accent);
    border: 0.5px solid var(--border-accent);
    border-radius: var(--radius);
  }

  .league-full {
    font-size: 13px;
    color: var(--text-muted);
  }

  .see-all {
    font-size: 13px;
    color: var(--text-accent);
  }

  .see-all:hover { text-decoration: underline; }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 10px;
  }

  .team-card {
    background: var(--surface-2);
    border: 0.5px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color .12s;
  }

  .team-card:hover { border-color: var(--border-strong); }

  .color-strip { display: flex; height: 6px; }
  .strip-seg { flex: 1; }

  .card-body { padding: 12px 14px; }

  .team-name {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .team-count {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 3px;
  }
</style>
