---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Sports Brand Color Codes - HEX, RGB, CMYK & Pantone | Best Color Codes"
  description="Official color codes for sports teams and brands. Browse by category - football, basketball, hockey, baseball, footwear, and more."
>
  <section class="hero">
    <div class="hero-inner">
      <div class="breadcrumb"><a href="/">Best Color Codes</a> <span>›</span> <span>Sports</span></div>
      <h1>Sports brand color codes</h1>
      <p class="hero-sub">Official HEX, RGB, CMYK, and Pantone color codes for sports teams and brands - browse by category.</p>
    </div>
  </section>

  <main class="main">
    <div class="category-grid">
      <a class="category-card" href="/sports/football/">
        <div class="category-icon">🏈</div>
        <div class="category-info">
          <p class="category-name">Football</p>
          <p class="category-desc">NFL team color codes</p>
        </div>
        <span class="card-arrow">›</span>
      </a>
      <a class="category-card" href="/sports/basketball/">
        <div class="category-icon">🏀</div>
        <div class="category-info">
          <p class="category-name">Basketball</p>
          <p class="category-desc">NBA team color codes</p>
        </div>
        <span class="card-arrow">›</span>
      </a>
      <a class="category-card" href="/sports/hockey/">
        <div class="category-icon">🏒</div>
        <div class="category-info">
          <p class="category-name">Hockey</p>
          <p class="category-desc">NHL team color codes</p>
        </div>
        <span class="card-arrow">›</span>
      </a>
      <a class="category-card" href="/sports/baseball/">
        <div class="category-icon">⚾</div>
        <div class="category-info">
          <p class="category-name">Baseball</p>
          <p class="category-desc">MLB team color codes</p>
        </div>
        <span class="card-arrow">›</span>
      </a>
      <a class="category-card" href="/sports/footwear/">
        <div class="category-icon">👟</div>
        <div class="category-info">
          <p class="category-name">Footwear</p>
          <p class="category-desc">Running and athletic shoe brand colors</p>
        </div>
        <span class="card-arrow">›</span>
      </a>
    </div>
  </main>
</Base>

<style>
  .hero {
    padding: 3rem 2rem 2.5rem;
    background: var(--surface-1);
    border-bottom: 0.5px solid var(--border);
  }

  .hero-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .breadcrumb {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 1rem;
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .breadcrumb a { color: var(--text-accent); }
  .breadcrumb a:hover { text-decoration: underline; }

  .hero-sub {
    font-size: 16px;
    color: var(--text-secondary);
    margin-top: 8px;
    line-height: 1.6;
  }

  .main {
    max-width: 900px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
  }

  .category-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px;
    background: var(--surface-2);
    border: 0.5px solid var(--border);
    border-radius: 12px;
    transition: background .12s, border-color .12s;
  }

  .category-card:hover {
    background: var(--surface-1);
    border-color: var(--border-strong);
  }

  .category-icon {
    font-size: 28px;
    flex-shrink: 0;
  }

  .category-info { flex: 1; }

  .category-name {
    font-size: 16px;
    font-weight: 500;
    color: var(--text-primary);
  }

  .category-desc {
    font-size: 13px;
    color: var(--text-secondary);
    margin-top: 2px;
  }

  .card-arrow {
    font-size: 18px;
    color: var(--text-muted);
  }
</style>
