---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';

const all = await getCollection('teams');
const brands = all.filter(t => t.data.league === 'Brand');
---

<Base
  title="Footwear Brand Color Codes — HEX, RGB, CMYK & Pantone | Best Color Codes"
  description="Official color codes for footwear and athletic shoe brands. Find exact HEX, RGB, CMYK, and Pantone values."
>
  <section class="hero">
    <div class="hero-inner">
      <div class="breadcrumb">
        <a href="/">Best Color Codes</a> <span>›</span>
        <a href="/sports/">Sports</a> <span>›</span>
        <span>Footwear</span>
      </div>
      <h1>Footwear brand color codes</h1>
      <p class="hero-sub">Official HEX, RGB, CMYK, and Pantone color codes for athletic footwear brands.</p>
    </div>
  </section>

  <main class="main">
    <div class="brand-grid">
      {brands.map(b => (
        <a class="brand-card" href={`/${b.data.slug}/`}>
          <div class="color-strip">
            {b.data.colors.map(c => (
              <div class="strip-seg" style={`background:${c.hex}`}></div>
            ))}
          </div>
          <div class="card-body">
            <p class="brand-name">{b.data.teamName}</p>
            <p class="brand-count">{b.data.colors.length} colors</p>
          </div>
        </a>
      ))}
    </div>
  </main>
</Base>

<style>
  .hero {
    padding: 3rem 2rem 2.5rem;
    background: var(--surface-1);
    border-bottom: 0.5px solid var(--border);
  }

  .hero-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .breadcrumb {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 1rem;
    display: flex;
    gap: 6px;
    align-items: center;
    flex-wrap: wrap;
  }

  .breadcrumb a { color: var(--text-accent); }
  .breadcrumb a:hover { text-decoration: underline; }

  .hero-sub {
    font-size: 16px;
    color: var(--text-secondary);
    margin-top: 8px;
    line-height: 1.6;
  }

  .main {
    max-width: 900px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
  }

  .brand-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
  }

  .brand-card {
    background: var(--surface-2);
    border: 0.5px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color .12s;
  }

  .brand-card:hover { border-color: var(--border-strong); }

  .color-strip { display: flex; height: 6px; }
  .strip-seg { flex: 1; }

  .card-body { padding: 14px 16px; }

  .brand-name {
    font-size: 15px;
    font-weight: 500;
    color: var(--text-primary);
  }

  .brand-count {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 4px;
  }
</style>
