---
import Base from '../../../layouts/Base.astro';
import JsonLd from '../../../components/JsonLd.astro';
import { site } from '../../../config/site';

const leagues = [
  { name: 'NHL', full: 'National Hockey League', slug: 'nhl-team-color-codes' },
];

const pageUrl = `${site.url}/sports/hockey/`;

const collectionPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Hockey Team Color Codes',
  description: 'Official color codes for NHL hockey teams.',
  url: pageUrl,
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Hockey Leagues',
  url: pageUrl,
  itemListElement: leagues.map((l, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: `${l.name} Team Colors`,
    url: `${site.url}/${l.slug}/`,
  })),
};
---

<Base
  title="Hockey Team Color Codes - NHL | Best Color Codes"
  description="Official color codes for NHL hockey teams. Find HEX, RGB, CMYK, and Pantone values for every National Hockey League team."
>
  <Fragment slot="head">
    <JsonLd schema={collectionPageSchema} />
    <JsonLd schema={itemListSchema} />
  </Fragment>
  <section class="hero">
    <div class="hero-inner">
      <div class="breadcrumb">
        <a href="/">Best Color Codes</a> <span>›</span>
        <a href="/sports/">Sports</a> <span>›</span>
        <span>Hockey</span>
      </div>
      <h1>Hockey team color codes</h1>
      <p class="hero-sub">Official HEX, RGB, CMYK, and Pantone color codes for every NHL team.</p>
    </div>
  </section>

  <main class="main">
    <div class="league-grid">
      {leagues.map(l => (
        <a class="league-card" href={`/${l.slug}/`}>
          <div class="league-badge">{l.name}</div>
          <div class="league-info">
            <p class="league-name">{l.name} team colors</p>
            <p class="league-full">{l.full}</p>
          </div>
          <span class="card-arrow">›</span>
        </a>
      ))}
    </div>
  </main>
</Base>

<style>
  .hero {
    padding: 3rem 2rem 2.5rem;
    background: var(--surface-1);
    border-bottom: 0.5px solid var(--border);
  }

  .hero-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .breadcrumb {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 1rem;
    display: flex;
    gap: 6px;
    align-items: center;
    flex-wrap: wrap;
  }

  .breadcrumb a { color: var(--text-accent); }
  .breadcrumb a:hover { text-decoration: underline; }

  .hero-sub {
    font-size: 16px;
    color: var(--text-secondary);
    margin-top: 8px;
    line-height: 1.6;
  }

  .main {
    max-width: 900px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
  }

  .league-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
  }

  .league-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px;
    background: var(--surface-2);
    border: 0.5px solid var(--border);
    border-radius: 12px;
    transition: background .12s, border-color .12s;
  }

  .league-card:hover {
    background: var(--surface-1);
    border-color: var(--border-strong);
  }

  .league-badge {
    font-size: 13px;
    font-weight: 600;
    padding: 6px 12px;
    background: var(--bg-accent);
    color: var(--text-accent);
    border: 0.5px solid var(--border-accent);
    border-radius: var(--radius);
    flex-shrink: 0;
    min-width: 52px;
    text-align: center;
  }

  .league-info { flex: 1; }

  .league-name {
    font-size: 15px;
    font-weight: 500;
    color: var(--text-primary);
  }

  .league-full {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 2px;
  }

  .card-arrow {
    font-size: 18px;
    color: var(--text-muted);
  }
</style>
